# Output files
output/

# Generated SF2 test corpus — reproducible from SID/ via sid_to_sf2.py;
# treat as ephemeral test artifacts, not source.
SF2/*.sf2
SF2/*.txt
SF2/**/*.sf2
SF2/**/*.txt

# Harness staging files (created in bin/ for F10-load tests)
bin/_*.sf2
bin/__sf2load_test__*.sf2
bin/__sf2dbg__*.sf2
# Throwaway probe + audit + verify scripts and their outputs (live in
# bin/_*.py / .csv / .txt; named with leading underscore by convention).
# Persistent investigation tools should go in pyscript/probe_*.py.
bin/_*.py
bin/_*.csv
bin/_*.txt
bin/_*.prg
# Generated SF2 + round-trip outputs from sid_to_sf2 / sf2_to_sid
# (reproducible from SID/; ephemeral test artifacts, not source).
bin/*.sf2
bin/*.txt
bin/*_rt.sid
bin/*_roundtrip.sid

# Issue-211 cron watcher state (harness-managed, not source)
.claude/sf2_issue_211_state.json

# Generated disassemblies
